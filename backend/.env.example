# Đổi các giá trị này khi deploy thật, KHÔNG commit file .env thật lên git
PORT=4000

# Secret dùng để ký HMAC cho checkpoint link (chống sửa tay URL)
CHECKPOINT_SECRET=x7Kp9mQ2wZvR4tLh8nY1sJ6bF3dC0aE5
JWT_SECRET=r2H9vN4kM7pQ1sT6xL3bW8dF0cA5yE2g

# URL frontend (để redirect sau khi hoàn thành 3 link)
FRONTEND_URL=http://localhost:5500

# URL backend chính nó (dùng để tạo callback URL cho các checkpoint)
BACKEND_URL=http://localhost:4000

# 3 link rút gọn kiếm tiền của bạn (Link4m, Yeumoney, ShorterLink...)
# Mỗi service thường có API riêng để tạo link kèm URL đích,
# ở đây giả lập bằng cách nối chuỗi ?to= cho dễ hiểu logic.
SHORTLINK_API_TOKEN=6a4b94abd9480b09be426d56
SHORTLINK_API_BASE=https://link4m.co/api-shorten/v2

# Thời gian sống của 1 phiên vượt link (phút)
SESSION_TTL_MINUTES=20

# Thời gian sống của unlock token sau khi vượt xong 3 link (giờ)
UNLOCK_TOKEN_TTL_HOURS=4
